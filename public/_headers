/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://embed.tawk.to https://va.tawk.to https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://embed.tawk.to; img-src 'self' data: blob: https:; connect-src 'self' blob: https://api2.mitienda.pe https://api.apis.net.pe https://api.nubefact.com https://*.tawk.to wss://*.tawk.to ws://localhost:* wss://localhost:* ws://127.0.0.1:* wss://127.0.0.1:*; frame-src https://embed.tawk.to; font-src 'self' data: https://fonts.gstatic.com https://embed.tawk.to; media-src 'self' blob:; worker-src 'self' blob:; frame-ancestors 'none';

# Cache estático agresivo
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# index.html no cachear (para que deploys tomen efecto inmediato)
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
